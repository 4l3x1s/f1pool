# ============================================================
# F1 2026 Pool — Environment Variables
# Copy this file to .env and fill in your values
# Then add these to Vercel: Settings → Environment Variables
# ============================================================

# --- VAPID Keys (for push notifications) ---
# Generate by running: node generate-vapid-keys.js
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
CONTACT_EMAIL=your-email@example.com

# --- Upstash Redis (free database for storing subscriptions) ---
# Get these from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# --- Cron Job Security ---
# A random string to protect the /api/check-and-notify endpoint
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your_random_secret_here
